# ===== Secrets — NEVER commit =====
# .env holds your OpenRouter key
.env
# private code-signing materials
cert/*.key
cert/*.p12

# NOTE: config/settings.ini IS tracked, but only with a placeholder API key.
# Your real key stays local and is protected from commits via skip-worktree
# (see README "Quick start"). Never replace the committed placeholder with a real key.

# ===== Generated / runtime =====
# Python virtualenv, recreated on first launch
lib/core/.venv/
**/__pycache__/
*.pyc
lib/core/vendor_site_packages/
lib/core/python/

# ===== Build artifacts =====
# compiled bundle, produced by build_app.sh
ImpressionistLLM.app/
# bare compiled binary
/ImpressionistLLM

# ===== Logs & scratch =====
logs/*
!logs/.gitkeep
temp/*
!temp/.gitkeep

# ===== macOS cruft =====
.DS_Store
**/.DS_Store

# ===== Claude Code local harness config =====
.claude/
